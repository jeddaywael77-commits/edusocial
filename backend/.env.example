# ─── Database ────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edusocial?schema=public"

# ─── Redis ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# ─── App ─────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ─── Upload ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
MEDIA_STORAGE_BASE_URL=http://localhost:3001/uploads

# ─── Search (Meilisearch) ────────────────────────
MEILISEARCH_HOST=localhost
MEILISEARCH_PORT=7700
MEILISEARCH_API_KEY=

# ─── AI Providers ────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
GROQ_API_KEY=
GROQ_MODEL=llama-3-70b-8192
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Qdrant (Vector DB) ─────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Media Storage ───────────────────────────────
STORAGE_TYPE=local
STORAGE_BUCKET=edusocial-media
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=debug

# ─── Sentry ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── OpenTelemetry ───────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
